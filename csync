#!/bin/bash

# Load core logic
source "${BASH_SOURCE%/*}/src/core.sh"

case "$1" in
    add)
        source "${BASH_SOURCE%/*}/src/commands/add.sh"
        shift
        cmd_add "$@"
        ;;
    init)
        source "${BASH_SOURCE%/*}/src/commands/init.sh"
        shift
        cmd_init "$@"
        ;;
    pull)
        source "${BASH_SOURCE%/*}/src/commands/pull.sh"
        shift
        cmd_pull "$@"
        ;;
    *)
        echo "Usage: csync <command> [args]"
        echo "Commands:"
        echo "  add <file_or_directory>  Add an item to the cloud vault"
        echo "  init                    Configure PC from sync map"
        echo "  pull                    Link missing items from cloud vault"
        exit 1
        ;;
esac
